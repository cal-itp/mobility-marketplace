<section class="container-sm my-5">
  <div class="row align-items-center">
    <div class="col-lg-6 offset-lg-1">
      <h1 class="fw-normal text-start mb-3">
        <span role="text">
          Modernize your transit system with free, guided support from <span class="text-nowrap">Cal-ITP</span>
        </span>
      </h1>
      <p class="text-body-xl mb-0">
        Whether it’s connecting your fleet, adding real-time updates, or launching tap to pay rides,
        <span class="text-nowrap">Cal-ITP</span> guides your agency every step of the way. Free support, proven tools, and
        pre-negotiated contracts put innovation within reach.
      </p>
    </div>
    <div class="col-lg-5">
      <img class="d-block w-100" src="/uploads/hero_home.png" alt="">
    </div>
  </div>
</section>

<section class="logo-strip">
  <div class="container-sm mb-4">
    <div class="d-flex gap-3 align-items-center justify-content-center justify-content-lg-start offset-lg-1">
      <h2 class="h4 lh-1 fw-normal mb-0">Agencies we work with</h2>
      <button class="logo-strip-pause-btn align-items-center justify-content-center" role="switch" aria-checked="true" hidden>
        <svg class="pause-icon" width="12" height="16" viewBox="0 0 12 16" fill="currentcolor" xmlns="http://www.w3.org/2000/svg">
          <title>Pause icon</title>
          <rect width="4" height="16" rx="2" />
          <rect x="8" width="4" height="16" rx="2" />
        </svg>
        <svg class="play-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentcolor" xmlns="http://www.w3.org/2000/svg">
          <title>Resume icon</title>
          <path
            d="M18.5 9.13398C19.1667 9.51888 19.1667 10.4811 18.5 10.866L6.5 17.7942C5.83333 18.1791 5 17.698 5 16.9282L5 3.0718C5 2.302 5.83333 1.82088 6.5 2.20578L18.5 9.13398Z"
          />
        </svg>
        <span class="screen-reader-text visually-hidden">Toggle animation</span>
      </button>
    </div>
  </div>
  <ul class="logo-strip-list">
    {% for agency in agencies -%}
      <li><img src="/uploads/{{ agency.logo }}" alt="{{ agency.name }}"></li>
    {% endfor %}
    {% for agency in agencies -%}
      <li><img src="/uploads/{{ agency.logo }}" alt="{{ agency.name }}" aria-hidden="true"></li>
    {% endfor %}
  </ul>
</section>

<section class="container-sm mt-5">
  <h2>Guides to plan, purchase, and launch</h2>
  <p class="gallery-description text-body-xl text-center">
    Our guides can help you leverage pre-approved MSAs and cut your procurement time.
  </p>
  <ul class="gallery-cards row">
    {% for card in galleryCards -%}
      <li class="col-md-6 col-lg-5 {% cycle 'offset-lg-1', '' %}">
        <div class="gallery-card">
          <h3 class="text-start mt-0">{{ card.title }}</h3>
          <p class="text-body-xl">{{ card.description }}</p>
          <a class="dl-button mt-3" href="{{ card.href }}">Read the {{ card.name }} guide</a>
          <img src="/uploads/{{ card.img }}" alt="{{ card.imgAlt }}">
        </div>
      </li>
    {% endfor %}
  </ul>
</section>

